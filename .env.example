# Local development only — points at the DEV Supabase project.
# Production values live in EAS (set via `eas env:create --environment production ...`)
# and are injected into builds automatically. Never put prod values in a local .env file.
#
# Supabase CLI project refs (used by package.json db:link:* scripts):
SUPABASE_DEV_REF=your-dev-project-ref
SUPABASE_PROD_REF=your-prod-project-ref

# Expo public env — read by lib/supabase.ts and the Google sign-in flow:
EXPO_PUBLIC_SUPABASE_URL=https://your-dev-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key-here
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-dev-google-web-client-id
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
